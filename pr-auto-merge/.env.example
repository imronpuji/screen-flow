# Salin file ini jadi ".env" lalu isi nilainya.
# Cara pakai (Mac/Linux): export $(cat .env | xargs) && npm start

# Personal Access Token GitHub (WAJIB).
# Buat di: https://github.com/settings/tokens
# Scope yang diperlukan: "repo" (classic) atau "Pull requests: Read & write" (fine-grained)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Default repo (opsional kalau kamu selalu kirim owner/repo di body curl)
GITHUB_OWNER=imronpuji
GITHUB_REPO=screen-flow

# merge | squash | rebase
MERGE_METHOD=merge

# Port server
PORT=3000
