{
  "name": "screen-flow",
  "private": true,
  "version": "0.1.0",
  "description": "Cinematic desktop screen recorder (Electron + React + ffmpeg)",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "build": "tsc -b && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b && tsc -p electron/tsconfig.json --noEmit",
    "smoke:export-progress": "node --experimental-strip-types scripts/smoke-export-progress.mts",
    "smoke:export-save": "node --experimental-strip-types scripts/smoke-export-save.mts",
    "smoke:cursor-events": "node --experimental-strip-types scripts/smoke-cursor-events.mts",
    "smoke:autozoom": "node --experimental-strip-types scripts/smoke-autozoom.mts",
    "smoke:export-autozoom": "node --experimental-strip-types scripts/smoke-export-autozoom.mts",
    "smoke:export-trim": "node --experimental-strip-types scripts/smoke-export-trim.mts",
    "smoke:cursor-smoothing": "node --experimental-strip-types scripts/smoke-cursor-smoothing.mts",
    "smoke:cursor-appearance": "node --experimental-strip-types scripts/smoke-cursor-appearance.mts",
    "smoke:cursor-prefs": "node --experimental-strip-types scripts/smoke-cursor-prefs.mts",
    "smoke:background": "node --experimental-strip-types scripts/smoke-background.mts",
    "smoke:background-prefs": "node --experimental-strip-types scripts/smoke-background-prefs.mts",
    "smoke:export-effects": "node --experimental-strip-types scripts/smoke-export-effects.mts",
    "smoke:camera": "node --experimental-strip-types scripts/smoke-camera.mts",
    "smoke:camera-devices": "node --experimental-strip-types scripts/smoke-camera-devices.mts",
    "smoke:camera-prefs": "node --experimental-strip-types scripts/smoke-camera-prefs.mts",
    "smoke:camera-sync": "node --experimental-strip-types scripts/smoke-camera-sync.mts",
    "smoke:export-camera": "node --experimental-strip-types scripts/smoke-export-camera.mts",
    "smoke:export-quality": "node --experimental-strip-types scripts/smoke-export-quality.mts",
    "smoke:export-format": "node --experimental-strip-types scripts/smoke-export-format.mts",
    "smoke:export-prefs": "node --experimental-strip-types scripts/smoke-export-prefs.mts",
    "smoke:beautify": "node --experimental-strip-types scripts/smoke-beautify.mts",
    "smoke:onboarding": "node --experimental-strip-types scripts/smoke-onboarding.mts",
    "smoke:shortcuts": "node --experimental-strip-types scripts/smoke-shortcuts.mts",
    "smoke:edit-history": "node --experimental-strip-types scripts/smoke-edit-history.mts",
    "smoke:timeline-cut": "node --experimental-strip-types scripts/smoke-timeline-cut.mts",
    "smoke:keep-ranges": "node --experimental-strip-types scripts/smoke-keep-ranges.mts",
    "smoke:timeline-snap": "node --experimental-strip-types scripts/smoke-timeline-snap.mts",
    "smoke:tooltips": "node --experimental-strip-types scripts/smoke-tooltips.mts",
    "smoke:timeline-markers": "node --experimental-strip-types scripts/smoke-timeline-markers.mts",
    "smoke:zoom-points": "node --experimental-strip-types scripts/smoke-zoom-points.mts",
    "smoke:editor-panels": "node --experimental-strip-types scripts/smoke-editor-panels.mts",
    "smoke:toast": "node --experimental-strip-types scripts/smoke-toast.mts",
    "smoke:export-size": "node --experimental-strip-types scripts/smoke-export-size.mts",
    "smoke:project-autosave": "node --experimental-strip-types scripts/smoke-project-autosave.mts"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^37.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
